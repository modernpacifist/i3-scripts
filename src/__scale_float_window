#!/bin/env bash

# TODO: must create a function for restoration and backup of the config file

if [[ -z $1 ]]; then
    # TODO: this error message with this condition make no sense
    echo '$1 $2 arguments were not specified'
    exit 1
fi

MONITOR_DIMENSIONS_FILE=$HOME/.monitor_dimensions.json
if [[ -f $MONITOR_DIMENSIONS_FILE ]]; then
    monitor_dimension_x=$(grep '"primary_x"' $MONITOR_DIMENSIONS_FILE | grep -o '[[:digit:]]*')
    monitor_dimension_y=$(grep '"primary_y"' $MONITOR_DIMENSIONS_FILE | grep -o '[[:digit:]]*')
fi

CONFIGFILE=$HOME/.scale_float_window.json
if [[ ! -f $CONFIGFILE ]]; then
    notify-send --expire-time=2000 '__scale_float_window: config was not found'
    exit 1
fi

CONFIGFILE_BAK="${CONFIGFILE}_bak"
# use backup if config file was overriden
if [[ ! -s $CONFIGFILE ]]; then
    notify-send --expire-time=3000 "__scale_float_window" "config was overriden!\nTrying to restore from backup..."

    if [[ ! -s $CONFIGFILE_BAK ]]; then
        notify-send --expire-time=3000 "__scale_float_window: backup config file is empty"
        exit 1
    fi

    if [[ ! -f $CONFIGFILE_BAK ]]; then
        notify-send --expire-time=3000 "__scale_float_window: backup config file does not exist"
        exit 1
    fi

    cp $CONFIGFILE_BAK $CONFIGFILE && notify-send --expire-time=3000 "__scale_float_window: config was restored"
fi

TOP_Y_POINT=53

function update_window_size() {
    updated_list=$(jq ".Windows | map(if .id == $1 then .window_g_y |= $2 else . end)" $CONFIGFILE)
    jq ".Windows |= $updated_list" $CONFIGFILE | jq . > temp.json && mv temp.json $CONFIGFILE
}

function update_window_flag() {
    updated_list=$(jq ".Windows | map(if .id == $focused_window_id then .resized_flag |= $1 else . end)" $CONFIGFILE)
    jq ".Windows |= $updated_list" $CONFIGFILE | jq . > temp.json && mv temp.json $CONFIGFILE
}

function resize_up() {
    # this must be checked if exists
    previous_size=$(jq ".Windows[] | select(.id == $2) | .window_g_y" $CONFIGFILE)
    flag_resized=$(jq ".Windows[] | select(.id == $2) | .resized_flag" $CONFIGFILE)
    vertical_diff=$(( $3 - $previous_size ))

    case $flag_resized in
        0) update_window_size $2 $3 && i3-msg "resize grow height $1 px or $1 ppt, move container up $1" && update_window_flag 1;;
        1) i3-msg "resize shrink height $vertical_diff px or $vertical_diff ppt, move container down $vertical_diff" && update_window_flag 0;;
    esac
}

function widen() {
    i3-msg "resize grow width $1 px or $1 ppt" && i3-msg "move container left $(($1/2)) px"
}

{ read window_g_x window_g_y ; } < <(xdotool getwindowfocus getwindowgeometry | grep Geometry | cut -d ":" -f2 | sed 's/ //g' | sed 's/x/ /g')
{ read window_loc_x window_loc_y ; } < <(xdotool getwindowfocus getwindowgeometry | grep Position | cut -d ":" -f2 | grep -o '[0-9]\+,[0-9]\+' | sed 's/,/ /g')

focused_window_id=$(xdotool getwindowfocus)
resized_flag=0

# this is bullshit
if (( $window_g_y == 2104 )); then
    resized_flag=1
fi

result=$(jq ".Windows[] | select(.id == $focused_window_id)" $CONFIGFILE)

# if value does not exist, add it to the JSON list
if [[ -z $result ]]; then
    new_val="{\"id\": $focused_window_id, \"resized_flag\": $resized_flag, \"window_g_y\": $window_g_y}"
    jq ".Windows += [$new_val]" $CONFIGFILE > temp.json && mv temp.json $CONFIGFILE
fi

window_border_width=$(grep '"WindowBorderWidth"' $CONFIGFILE | grep -o '[[:digit:]]*')
status_bar_height=$(grep '"StatusBarWidth"' $CONFIGFILE | grep -o '[[:digit:]]*')

offset_value=$(( totalscreensize - focused_container_size - window_centre ))
echo $offset_value
resize_value=$(( $monitor_dimension_y - $window_g_y - $TOP_Y_POINT - $window_border_width ))

case $1 in
    'w') resize_up $resize_value $focused_window_id $window_g_y;;
    'a') resize_horizontally $resize_value $flag_resized $focused_window_id;;

    '1') i3-msg "resize shrink width $2 px or $2 ppt, move container right $2 px";;
    # restoring the flag if window was resized vertically
    '2') i3-msg "resize grow height $2 px or $2 ppt, move container up $2 px" && update_window_flag 0;;
    '3') i3-msg "resize shrink height $2 px or $2 ppt, move container down $2 px" && update_window_flag 0;;
    '4') i3-msg "resize grow width $2 px or $2 ppt, move container left $2 px";;

    '5') i3-msg "resize shrink width $2 px or $2 ppt";;
    '6') i3-msg "resize grow height $2 px or $2 ppt" && update_window_flag 0;;
    '7') i3-msg "resize shrink height $2 px or $2 ppt" && update_window_flag 0;;
    '8') i3-msg "resize grow width $2 px or $2 ppt";;

    'widen') widen $2
esac

# temp backup mechanism
if [[ -s $CONFIGFILE ]]; then
    cp $CONFIGFILE $CONFIGFILE_BAK
fi
