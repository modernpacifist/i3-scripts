#!/bin/env bash

if [[ -z $1 ]]; then
    echo '$1 $2 arguments were not specified'
    exit 1
fi

MONITOR_DIMENSIONS_FILE=$HOME/.monitor_dimensions.json
if [[ -f $MONITOR_DIMENSIONS_FILE ]]; then
    primary_max_x=$(grep '"primary_x"' $MONITOR_DIMENSIONS_FILE | grep -o '[[:digit:]]*')
    primary_max_y=$(grep '"primary_y"' $MONITOR_DIMENSIONS_FILE | grep -o '[[:digit:]]*')
fi

CONFIGFILE=$HOME/.scale_float_window.json
if [[ ! -f $CONFIGFILE ]]; then
    echo 'No config file found'
    exit 1
fi

function save_window_size() {
    sed -i "s/\"window_g_y\": [0-9]*/\"window_g_y\": $1/" $CONFIGFILE
}

function change_flag_to() {
    sed -i "s/\"VerticalResizeFlag\": [0-9]*/\"VerticalResizeFlag\": $1/" $CONFIGFILE
}

function screen_vertical_resize() {
    wingow_g_y_config=$(grep '"window_g_y"' $CONFIGFILE | grep -o '[[:digit:]]*')
    vertical_diff=$(( $window_g_y - $wingow_g_y_config ))

    case $2 in
        0) save_window_size $window_g_y && i3-msg "resize grow height $1 px or $1 ppt, move container up $1" && change_flag_to 1;;
        1) i3-msg "resize shrink height $vertical_diff px or $vertical_diff ppt, move container down $vertical_diff" && change_flag_to 0;;
    esac
}

{ read window_g_x window_g_y ; } < <(xdotool getwindowfocus getwindowgeometry | grep Geometry | cut -d ":" -f2 | sed 's/ //g' | sed 's/x/ /g')
focused_window_id=$(xdotool getwindowfocus)
resized_flag=0

if (( $window_g_y == 2104 )); then
    resized_flag=1
fi

result=$(jq ".Windows[] | select(.id == $focused_window_id) " $CONFIGFILE)
new_val="{\"id\": $focused_window_id, \"resized_flag\": $resized_flag, \"window_g_y\": $window_g_y}"

# if value does not exist, add it to the JSON list
if [[ -z $result ]]; then
  new_json_list=$(jq '.Windows' $CONFIGFILE | jq --argjson new_val "$new_val" "[.[], $new_val]")
  jq ".Windows = $new_json_list" $CONFIGFILE > temp.json
  cat temp.json > $CONFIGFILE
else
  echo "Value found in JSON list: $result"
fi


window_border_width=$(grep '"WindowBorderWidth"' $CONFIGFILE | grep -o '[[:digit:]]*')
status_bar_width=$(grep '"StatusBarWidth"' $CONFIGFILE | grep -o '[[:digit:]]*')
flag_resized=$(grep '"VerticalResizeFlag"' $CONFIGFILE | grep -o '[[:digit:]]*')

resize_value=$(( $primary_max_y - $window_g_y - $status_bar_width - $window_border_width - $window_border_width ))

case $1 in
    'w') screen_vertical_resize $resize_value $flag_resized;;

    '1') i3-msg "resize shrink width $2 px or $2 ppt, move container right $2 px";;
    # restoring the flag if window was resized vertically
    '2') i3-msg "resize grow height $2 px or $2 ppt, move container up $2 px" && change_flag_to 0;;
    '3') i3-msg "resize shrink height $2 px or $2 ppt, move container down $2 px" && change_flag_to 0;;
    '4') i3-msg "resize grow width $2 px or $2 ppt, move container left $2 px";;

    '5') i3-msg "resize shrink width $2 px or $2 ppt";;
    '6') i3-msg "resize grow height $2 px or $2 ppt" && change_flag_to 0;;
    '7') i3-msg "resize shrink height $2 px or $2 ppt" && change_flag_to 0;;
    '8') i3-msg "resize grow width $2 px or $2 ppt";;
esac
